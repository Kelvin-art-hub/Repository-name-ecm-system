# ECM System Environment Configuration
APP_NAME=ECM System API
APP_VERSION=2.0.0
DEBUG=true
SECRET_KEY=ecm-super-secret-key-change-in-production-2024

# Database - PostgreSQL (change to your DB credentials)
DATABASE_URL=postgresql://ecm_user:ecm_password@localhost:5432/ecm_db

# Redis
REDIS_URL=redis://localhost:6379
REDIS_BOM_LOCK_TTL=300

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_ECR_TOPIC=ecr-events
KAFKA_ECN_TOPIC=ecn-events
KAFKA_AUDIT_TOPIC=audit-events
KAFKA_NOTIFICATION_TOPIC=notifications

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=480
ALGORITHM=HS256
