# ── Copy this to .env for local dev ──────────────────────────
# On Railway, set these in the Variables tab (NOT as a file)

APP_NAME=ECM System API
APP_VERSION=2.0.0
DEBUG=false

# CHANGE THIS — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=ecm-super-secret-key-change-in-production-2024

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Railway auto-injects DATABASE_URL when you add a PostgreSQL plugin
DATABASE_URL=sqlite:///./ecm_system.db

# CORS — set to your Vercel frontend URL in production
# Example: https://ecm-system.vercel.app
# Use * to allow all (local dev only)
CORS_ORIGINS=https://your-app.vercel.app

# Redis (optional — falls back to in-memory)
REDIS_URL=redis://localhost:6379

# Kafka (optional — falls back to logging)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
